# AHAM PREMAH FOUNDATION — Apache Configuration
# Place this file in the root of your website (same folder as index.php)

Options -Indexes
DirectoryIndex index.php index.html

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force www redirect (optional — comment out if not needed)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Remove trailing slash (except root)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [R=301,L]

    # Block access to includes folder directly
    RewriteRule ^includes/ - [F,L]
</IfModule>

# PHP settings (uncomment if your host allows)
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 10M
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 3 months"
    ExpiresByType image/png "access plus 3 months"
</IfModule>
